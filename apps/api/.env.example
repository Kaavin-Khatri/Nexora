# apps/api — copy to .env and fill in (never commit .env)
# If your password has special characters (@ : / # % ?), URL-encode them.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
# Session pooler (5432, same host/user as above). The "true" direct host
# db.<ref>.supabase.co is IPv6-only and unreachable from IPv4-only networks.
DIRECT_DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Only for legacy HS256 projects. Leave EMPTY on JWKS projects (this one) —
# the API then verifies tokens via /auth/v1/.well-known/jwks.json.
SUPABASE_JWT_SECRET=
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile
ALLOWED_ORIGINS=http://localhost:3000
FASTEMBED_CACHE=.fastembed_cache
